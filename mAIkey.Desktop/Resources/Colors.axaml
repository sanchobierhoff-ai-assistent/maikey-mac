<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- mAIkey design-tokens — Avalonia-port van frontend/Resources/     -->
  <!-- Colors.Dark.xaml + Colors.Light.xaml. Thema-onafhankelijke       -->
  <!-- tokens (radius/spacing/fonts) staan onderaan; kleuren per        -->
  <!-- ThemeVariant in ThemeDictionaries.                               -->
  <!-- ═══════════════════════════════════════════════════════════════ -->

  <ResourceDictionary.ThemeDictionaries>

    <!-- ═══════════════════ DONKER ═══════════════════ -->
    <ResourceDictionary x:Key="Dark">
      <!-- Surfaces -->
      <SolidColorBrush x:Key="Bg0" Color="#0B0B0D"/>
      <SolidColorBrush x:Key="Bg1" Color="#111114"/>
      <SolidColorBrush x:Key="Bg2" Color="#18181C"/>
      <SolidColorBrush x:Key="Bg3" Color="#1F1F24"/>
      <SolidColorBrush x:Key="Bg4" Color="#26262C"/>
      <!-- Borders -->
      <SolidColorBrush x:Key="Border1" Color="#26262C"/>
      <SolidColorBrush x:Key="BorderStrong" Color="#32323A"/>
      <!-- Text -->
      <SolidColorBrush x:Key="Text1" Color="#F2F2F5"/>
      <SolidColorBrush x:Key="Text2" Color="#9A9AA3"/>
      <SolidColorBrush x:Key="Text3" Color="#5E5E66"/>
      <!-- Accent -->
      <SolidColorBrush x:Key="Accent" Color="#F5A524"/>
      <SolidColorBrush x:Key="AccentSoft" Color="#29F5A524"/>
      <SolidColorBrush x:Key="AccentDim" Color="#C27F0E"/>
      <!-- Surfaces — legacy namen -->
      <SolidColorBrush x:Key="WindowBackground" Color="#111114"/>
      <SolidColorBrush x:Key="ContentBackground" Color="#18181C"/>
      <SolidColorBrush x:Key="CardBackground" Color="#18181C"/>
      <SolidColorBrush x:Key="InputBackground" Color="#1F1F24"/>
      <!-- Hover/interactie -->
      <SolidColorBrush x:Key="BackgroundHover" Color="#26262C"/>
      <SolidColorBrush x:Key="BackgroundActive" Color="#32323A"/>
      <!-- Borders — legacy namen -->
      <SolidColorBrush x:Key="BorderStandard" Color="#26262C"/>
      <SolidColorBrush x:Key="BorderLight" Color="#32323A"/>
      <SolidColorBrush x:Key="BorderDark" Color="#1F1F24"/>
      <!-- Text — legacy namen -->
      <SolidColorBrush x:Key="TextPrimary" Color="#F2F2F5"/>
      <SolidColorBrush x:Key="TextSecondary" Color="#9A9AA3"/>
      <SolidColorBrush x:Key="TextTertiary" Color="#5E5E66"/>
      <SolidColorBrush x:Key="TextDisabled" Color="#5E5E66"/>
      <!-- Accent stat cards -->
      <SolidColorBrush x:Key="AccentBlue" Color="#3A6EA5"/>
      <SolidColorBrush x:Key="AccentGreen" Color="#3A8F7A"/>
      <SolidColorBrush x:Key="AccentPurple" Color="#6B5BA6"/>
      <SolidColorBrush x:Key="AccentYellow" Color="#A98A3F"/>
      <!-- Semantische status -->
      <SolidColorBrush x:Key="Success" Color="#10B981"/>
      <SolidColorBrush x:Key="Warning" Color="#F59E0B"/>
      <SolidColorBrush x:Key="Error" Color="#EF4444"/>
      <SolidColorBrush x:Key="Info" Color="#60A5FA"/>
      <SolidColorBrush x:Key="Danger" Color="#EF4444"/>
      <!-- Gradients -->
      <LinearGradientBrush x:Key="GradientStatBlue" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#3A6EA5" Offset="0.0"/><GradientStop Color="#2E5A85" Offset="1.0"/>
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="GradientStatGreen" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#3A8F7A" Offset="0.0"/><GradientStop Color="#2E7361" Offset="1.0"/>
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="GradientStatPurple" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#6B5BA6" Offset="0.0"/><GradientStop Color="#554985" Offset="1.0"/>
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="GradientStatYellow" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#A98A3F" Offset="0.0"/><GradientStop Color="#876E32" Offset="1.0"/>
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="GradientAccentButton" StartPoint="0%,0%" EndPoint="100%,0%">
        <GradientStop Color="#F5A524" Offset="0.0"/><GradientStop Color="#F0941A" Offset="1.0"/>
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="GradientAccentButtonHover" StartPoint="0%,0%" EndPoint="100%,0%">
        <GradientStop Color="#F7B347" Offset="0.0"/><GradientStop Color="#F5A524" Offset="1.0"/>
      </LinearGradientBrush>
      <!-- Shadow -->
      <Color x:Key="ShadowColor">#000000</Color>
      <!-- Backward-compat aliassen -->
      <SolidColorBrush x:Key="BackgroundDark" Color="#111114"/>
      <SolidColorBrush x:Key="BackgroundMedium" Color="#18181C"/>
      <SolidColorBrush x:Key="BackgroundCard" Color="#18181C"/>
      <SolidColorBrush x:Key="BackgroundInput" Color="#1F1F24"/>
      <SolidColorBrush x:Key="BorderMedium" Color="#26262C"/>
      <SolidColorBrush x:Key="TextAccent" Color="#F2F2F5"/>
      <SolidColorBrush x:Key="AccentPrimary" Color="#F5A524"/>
      <SolidColorBrush x:Key="GlassLight" Color="#18181C"/>
      <!-- Thema-specifiek -->
      <LinearGradientBrush x:Key="TitlebarBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="#131316" Offset="0"/><GradientStop Color="#0D0D10" Offset="1"/>
      </LinearGradientBrush>
      <SolidColorBrush x:Key="AccentForeground" Color="#2B2418"/>
      <SolidColorBrush x:Key="AccentBorderSubtle" Color="#47F5A524"/>
      <SolidColorBrush x:Key="AccentWashTop" Color="#0FF5A524"/>
      <SolidColorBrush x:Key="AccentWashBottom" Color="#05F5A524"/>
    </ResourceDictionary>

    <!-- ═══════════════════ LICHT (taupe/linnen) ═══════════════════ -->
    <ResourceDictionary x:Key="Light">
      <!-- Surfaces -->
      <SolidColorBrush x:Key="Bg0" Color="#EDE4D0"/>
      <SolidColorBrush x:Key="Bg1" Color="#F4EEDE"/>
      <SolidColorBrush x:Key="Bg2" Color="#FBF6E9"/>
      <SolidColorBrush x:Key="Bg3" Color="#EFE7D2"/>
      <SolidColorBrush x:Key="Bg4" Color="#E5DABE"/>
      <!-- Borders -->
      <SolidColorBrush x:Key="Border1" Color="#E2D8BD"/>
      <SolidColorBrush x:Key="BorderStrong" Color="#CFC2A0"/>
      <!-- Text -->
      <SolidColorBrush x:Key="Text1" Color="#2C2820"/>
      <SolidColorBrush x:Key="Text2" Color="#6B6354"/>
      <SolidColorBrush x:Key="Text3" Color="#9B927E"/>
      <!-- Accent -->
      <SolidColorBrush x:Key="Accent" Color="#F5A524"/>
      <SolidColorBrush x:Key="AccentSoft" Color="#3DF5A524"/>
      <SolidColorBrush x:Key="AccentDim" Color="#C27F0E"/>
      <!-- Surfaces — legacy namen -->
      <SolidColorBrush x:Key="WindowBackground" Color="#F4EEDE"/>
      <SolidColorBrush x:Key="ContentBackground" Color="#FBF6E9"/>
      <SolidColorBrush x:Key="CardBackground" Color="#FBF6E9"/>
      <SolidColorBrush x:Key="InputBackground" Color="#EFE7D2"/>
      <!-- Hover/interactie -->
      <SolidColorBrush x:Key="BackgroundHover" Color="#E5DABE"/>
      <SolidColorBrush x:Key="BackgroundActive" Color="#CFC2A0"/>
      <!-- Borders — legacy namen -->
      <SolidColorBrush x:Key="BorderStandard" Color="#E2D8BD"/>
      <SolidColorBrush x:Key="BorderLight" Color="#CFC2A0"/>
      <SolidColorBrush x:Key="BorderDark" Color="#EFE7D2"/>
      <!-- Text — legacy namen -->
      <SolidColorBrush x:Key="TextPrimary" Color="#2C2820"/>
      <SolidColorBrush x:Key="TextSecondary" Color="#6B6354"/>
      <SolidColorBrush x:Key="TextTertiary" Color="#9B927E"/>
      <SolidColorBrush x:Key="TextDisabled" Color="#9B927E"/>
      <!-- Accent stat cards -->
      <SolidColorBrush x:Key="AccentBlue" Color="#3A6EA5"/>
      <SolidColorBrush x:Key="AccentGreen" Color="#3A8F7A"/>
      <SolidColorBrush x:Key="AccentPurple" Color="#6B5BA6"/>
      <SolidColorBrush x:Key="AccentYellow" Color="#A98A3F"/>
      <!-- Semantische status -->
      <SolidColorBrush x:Key="Success" Color="#0E9C6E"/>
      <SolidColorBrush x:Key="Warning" Color="#D98E0F"/>
      <SolidColorBrush x:Key="Error" Color="#D33A3A"/>
      <SolidColorBrush x:Key="Info" Color="#3479DB"/>
      <SolidColorBrush x:Key="Danger" Color="#D33A3A"/>
      <!-- Gradients -->
      <LinearGradientBrush x:Key="GradientStatBlue" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#3A6EA5" Offset="0.0"/><GradientStop Color="#2E5A85" Offset="1.0"/>
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="GradientStatGreen" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#3A8F7A" Offset="0.0"/><GradientStop Color="#2E7361" Offset="1.0"/>
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="GradientStatPurple" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#6B5BA6" Offset="0.0"/><GradientStop Color="#554985" Offset="1.0"/>
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="GradientStatYellow" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#A98A3F" Offset="0.0"/><GradientStop Color="#876E32" Offset="1.0"/>
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="GradientAccentButton" StartPoint="0%,0%" EndPoint="100%,0%">
        <GradientStop Color="#F5A524" Offset="0.0"/><GradientStop Color="#F0941A" Offset="1.0"/>
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="GradientAccentButtonHover" StartPoint="0%,0%" EndPoint="100%,0%">
        <GradientStop Color="#F7B347" Offset="0.0"/><GradientStop Color="#F5A524" Offset="1.0"/>
      </LinearGradientBrush>
      <!-- Shadow -->
      <Color x:Key="ShadowColor">#3A2A10</Color>
      <!-- Backward-compat aliassen -->
      <SolidColorBrush x:Key="BackgroundDark" Color="#F4EEDE"/>
      <SolidColorBrush x:Key="BackgroundMedium" Color="#FBF6E9"/>
      <SolidColorBrush x:Key="BackgroundCard" Color="#FBF6E9"/>
      <SolidColorBrush x:Key="BackgroundInput" Color="#EFE7D2"/>
      <SolidColorBrush x:Key="BorderMedium" Color="#E2D8BD"/>
      <SolidColorBrush x:Key="TextAccent" Color="#2C2820"/>
      <SolidColorBrush x:Key="AccentPrimary" Color="#F5A524"/>
      <SolidColorBrush x:Key="GlassLight" Color="#FBF6E9"/>
      <!-- Thema-specifiek -->
      <LinearGradientBrush x:Key="TitlebarBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="#F8F2E0" Offset="0"/><GradientStop Color="#F1EAD5" Offset="1"/>
      </LinearGradientBrush>
      <SolidColorBrush x:Key="AccentForeground" Color="#1A1410"/>
      <SolidColorBrush x:Key="AccentBorderSubtle" Color="#8CF5A524"/>
      <SolidColorBrush x:Key="AccentWashTop" Color="#38F5A524"/>
      <SolidColorBrush x:Key="AccentWashBottom" Color="#14F5A524"/>
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

  <!-- ═══════════ Thema-onafhankelijke tokens ═══════════ -->
  <!-- Lettertypen -->
  <FontFamily x:Key="FontUi">avares://mAIkey.Desktop/Resources/Fonts#Geist</FontFamily>
  <FontFamily x:Key="FontMono">avares://mAIkey.Desktop/Resources/Fonts#JetBrains Mono</FontFamily>

  <!-- Corner radius -->
  <CornerRadius x:Key="RadiusSm">6</CornerRadius>
  <CornerRadius x:Key="RadiusMd">10</CornerRadius>
  <CornerRadius x:Key="RadiusLg">14</CornerRadius>
  <CornerRadius x:Key="RadiusXl">18</CornerRadius>
  <CornerRadius x:Key="CornerRadiusStandard">10</CornerRadius>
  <CornerRadius x:Key="CornerRadiusCard">14</CornerRadius>
  <CornerRadius x:Key="CornerRadiusPill">25</CornerRadius>
  <CornerRadius x:Key="CornerRadiusWindow">18</CornerRadius>

  <!-- Spacing -->
  <Thickness x:Key="PaddingStandard">12</Thickness>
  <Thickness x:Key="PaddingCard">16</Thickness>
  <Thickness x:Key="PaddingLarge">24</Thickness>

</ResourceDictionary>
