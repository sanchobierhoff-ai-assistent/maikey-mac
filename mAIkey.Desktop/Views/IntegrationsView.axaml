<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="mAIkey.Desktop.Views.IntegrationsView">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="28,8,28,28" Spacing="20" MaxWidth="860">

      <StackPanel Spacing="4">
        <TextBlock Classes="eyebrow" Text="INTEGRATIES"/>
        <TextBlock Classes="title" Text="Koppelingen"/>
        <TextBlock Classes="subtitle"
                   Text="Stuur AI-resultaten rechtstreeks naar je favoriete tools."/>
      </StackPanel>

      <TextBlock Name="StatusText" Classes="muted" Text="Status laden..."/>
      <StackPanel Name="IntegrationsPanel" Spacing="10"/>

    </StackPanel>
  </ScrollViewer>
</UserControl>