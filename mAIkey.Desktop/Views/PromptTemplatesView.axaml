<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="mAIkey.Desktop.Views.PromptTemplatesView">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="28,8,28,28" Spacing="20" MaxWidth="860">

      <!-- Header -->
      <StackPanel Spacing="4">
        <TextBlock Classes="eyebrow" Text="TEMPLATES"/>
        <TextBlock Classes="title" Text="Prompt-templates"/>
        <TextBlock Classes="subtitle"
                   Text="Kant-en-klare prompts. Kies er een om als hotkey te gebruiken."/>
      </StackPanel>

      <!-- Status / melding -->
      <TextBlock Name="StatusText" Classes="muted" Text="Templates laden..."/>

      <!-- Dynamisch gevulde lijst -->
      <StackPanel Name="TemplatesPanel" Spacing="12"/>

    </StackPanel>
  </ScrollViewer>
</UserControl>