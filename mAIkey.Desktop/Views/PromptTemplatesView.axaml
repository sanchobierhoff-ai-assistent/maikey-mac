<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="mAIkey.Desktop.Views.PromptTemplatesView"
             Background="{DynamicResource Bg1}">

  <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="36,32,36,40">
    <StackPanel MaxWidth="760">

      <!-- Header -->
      <TextBlock Text="PROMPTS" FontSize="11" FontWeight="SemiBold"
                 Foreground="{DynamicResource Text3}" Margin="0,0,0,6"/>
      <TextBlock Text="Custom Prompts" FontSize="28" FontWeight="SemiBold"
                 Foreground="{DynamicResource Text1}" Margin="0,0,0,4"/>
      <TextBlock Text="Kies een template en voeg toe aan je hotkeys"
                 FontSize="13" Foreground="{DynamicResource Text3}" Margin="0,0,0,24"/>

      <!-- Zoeken -->
      <TextBox Name="SearchBox" Height="40" FontSize="13" Margin="0,0,0,20"
               Watermark="Zoek je favoriete template…"
               VerticalContentAlignment="Center" TextChanged="Search_Changed"/>

      <TextBlock Name="StatusText" Classes="muted" Text="Templates laden..."/>
      <StackPanel Name="CategoriesPanel" Spacing="0"/>

    </StackPanel>
  </ScrollViewer>
</UserControl>