<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="mAIkey.Desktop.Windows.GitHubConfigWindow"
        Title="GitHub verbinden"
        Width="480" Height="560"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Bg1}">

  <ScrollViewer>
    <StackPanel Margin="28" Spacing="16">

      <StackPanel Spacing="4">
        <TextBlock Classes="eyebrow" Text="INTEGRATIE"/>
        <TextBlock Classes="title" Text="GitHub" FontSize="24"/>
        <TextBlock Classes="subtitle" FontSize="13"
                   Text="Verbind met een Personal Access Token (repo-rechten). Aanmaken via github.com → Settings → Developer settings → Tokens."/>
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="Personal Access Token" Classes="muted"/>
        <TextBox Name="TokenBox" PasswordChar="●" Watermark="ghp_…"/>
      </StackPanel>

      <Button Name="TestBtn" Classes="ghost" Content="Test verbinding"
              HorizontalAlignment="Left" Click="Test_Click"/>

      <StackPanel Name="RepoSection" Spacing="12" IsVisible="False">
        <StackPanel Spacing="6">
          <TextBlock Text="Standaard-repository" Classes="muted"/>
          <ComboBox Name="RepoCombo" HorizontalAlignment="Stretch"/>
        </StackPanel>
        <StackPanel Spacing="6">
          <TextBlock Text="Standaardlabels (komma-gescheiden, optioneel)" Classes="muted"/>
          <TextBox Name="LabelsBox" Watermark="bug, enhancement"/>
        </StackPanel>
      </StackPanel>

      <TextBlock Name="StatusText" Classes="muted" IsVisible="False" TextWrapping="Wrap"/>

      <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
        <Button Name="SaveBtn" Classes="accent" Content="Opslaan" Click="Save_Click" IsEnabled="False"/>
        <Button Classes="ghost" Content="Annuleren" Click="Cancel_Click"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</Window>