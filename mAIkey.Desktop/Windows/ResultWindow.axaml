<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="mAIkey.Desktop.Windows.ResultWindow"
        Title="mAIkey — Resultaat"
        Width="600" Height="500"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="40"
        Background="#0B0B0D">

  <DockPanel>
    <!-- Title bar -->
    <Border DockPanel.Dock="Top" Height="40" Name="ResultTitleBar"
            Background="Transparent">
      <Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                    VerticalAlignment="Center" Margin="16,0" Spacing="8">
          <Border Background="#18181C" BorderBrush="#32323A" BorderThickness="1"
                  CornerRadius="5" Width="28" Height="20" Padding="2">
            <TextBlock Text="AI" FontSize="10" FontWeight="ExtraBold"
                       Foreground="#F5A524" HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="Resultaat" FontSize="12" Foreground="#9A9AA3"
                     VerticalAlignment="Center"/>
        </StackPanel>
        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                Width="46" Height="40" Content="✕"
                Background="Transparent" BorderThickness="0" CornerRadius="0"
                Foreground="#9A9AA3" FontSize="10"
                Click="CloseBtn_Click" Name="ResultCloseBtn"/>
      </Grid>
    </Border>

    <!-- Content -->
    <DockPanel Margin="20,0,20,20">
      <!-- Bottom buttons -->
      <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                  HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
        <Button Classes="ghost" Content="Kopieer" Name="CopyBtn"
                Padding="16,8" FontSize="12" Click="CopyBtn_Click"/>
        <Button Classes="accent" Content="Gebruiken" Name="UseBtn"
                Padding="16,8" FontSize="12" Click="UseBtn_Click"/>
      </StackPanel>

      <!-- Result text -->
      <TextBox Name="ResultTextBox" AcceptsReturn="True" TextWrapping="Wrap"
               IsReadOnly="True" Background="#18181C" BorderBrush="#26262C"
               BorderThickness="1" CornerRadius="10" Padding="16"
               FontSize="13" Foreground="#F2F2F5"/>
    </DockPanel>
  </DockPanel>
</Window>
